# Query Engine Platform Secrets
# Copy to .env and fill in values.
# Used by infra scripts to create K8s resources.

# GCP / GKE
GCP_PROJECT=agent-playground-491316
GCP_ZONE=africa-south1-a
GKE_CLUSTER_NAME=query-engine
GKE_MACHINE_TYPE=e2-medium

# Infrastructure
CLOUDFLARE_API_TOKEN=
QE_DOMAIN=queryengine.alreadyhadthisdomainhandy.acses.ai
QE_EMAIL=laurence@robothouse.io
QE_NAMESPACE=query-engine
TRAEFIK_STATIC_IP=

# Database passwords
NEO4J_PASSWORD=
POSTGRES_PASSWORD=

# API keys
OPENAI_API_KEY=
GCS_CREDENTIALS_JSON=

# GCS
GCS_BUCKET=query-engine-upload-data

# Optional overrides (defaults shown)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
